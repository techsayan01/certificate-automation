# ── Mongo ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=certificate_automation

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate session secret with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-generate-with-secrets.token_urlsafe

# Generate Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# ── Service ─────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000
ENV=development

# ── Bootstrap admin (only used on first boot when no users exist) ───────────
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# ── Canva (global Cert-Automate integration — one app for every festival) ───
# Each festival gets its own refresh_token but they all use the same
# OAuth client. Get these from canva.com/developers → your integration.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Phase 2 local storage for uploaded laurels. Phase 4 migrates this to GCS.
LAUREL_STORAGE_DIR=backend/data/laurels

# ── Cloud Tasks (production only — dev uses BackgroundTasks) ────────────────
# When ENV=production, these are required so the dispatcher knows where
# to enqueue async work. See infra/README.md for setup.
GCP_PROJECT=
CLOUD_TASKS_LOCATION=
CLOUD_TASKS_QUEUE=cert-runs
CLOUD_TASKS_SA_EMAIL=
