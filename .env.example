# ── Canva ─────────────────────────────────────────────────────────────────────
CANVA_CLIENT_ID=your_canva_client_id
CANVA_CLIENT_SECRET=your_canva_client_secret
CANVA_BRAND_TEMPLATE_ID=OABxxxxxxxxxxxxxxxx   # ID of your published brand template

# Text field names as labelled inside the Canva brand template
CANVA_NAME_FIELD=Name
CANVA_PROJECT_FIELD=Project
CANVA_CATEGORY_FIELD=Category

# OAuth redirect (leave as-is for local runs)
CANVA_REDIRECT_URI=http://localhost:8080/callback
CANVA_TOKEN_FILE=canva_token.json

# Polling config (seconds)
CANVA_REQUEST_DELAY_SECONDS=1.0
CANVA_POLL_INTERVAL_SECONDS=3.0
CANVA_POLL_TIMEOUT_SECONDS=180

# ── Gmail ─────────────────────────────────────────────────────────────────────
GMAIL_CREDENTIALS_FILE=credentials.json   # downloaded from Google Cloud Console
GMAIL_TOKEN_FILE=gmail_token.json

# ── Email content ─────────────────────────────────────────────────────────────
EMAIL_SUBJECT=Congratulations — Your Certificate is Here!
EMAIL_FROM_NAME=Your Organisation
EMAIL_TEMPLATE_DIR=email_sender/templates
DEFAULT_TEMPLATE=default.html

# ── CSV / paths ───────────────────────────────────────────────────────────────
CSV_PATH=data/recipients.csv
OUTPUT_DIR=data/output

# CSV column mapping  (FilmFreeway export defaults shown)
CSV_FIRST_NAME_COL=First Name
CSV_LAST_NAME_COL=Last Name
CSV_EMAIL_COL=Email
CSV_PROJECT_COL=Project Title
CSV_CATEGORY_COL=Submission Categories

# Optional: only process rows where Submission Status == this value
# Leave blank to process all rows
CSV_FILTER_STATUS=

# ── Misc ──────────────────────────────────────────────────────────────────────
DRY_RUN=false
