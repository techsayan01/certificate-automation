# ── Canva (shared across all projects) ────────────────────────────────────────
# From https://www.canva.com/developers → your integration
CANVA_CLIENT_ID=your_canva_client_id
CANVA_CLIENT_SECRET=your_canva_client_secret
CANVA_BRAND_TEMPLATE_ID=OABxxxxxxxxxxxxxxxx

# ── Global defaults (each project .env can override these) ────────────────────
OUTPUT_DIR=data/output
DEFAULT_TEMPLATE=default.html
EMAIL_TEMPLATE_DIR=email_sender/templates
DRY_RUN=false
