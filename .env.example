# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (Download JSON, open it, copy the values from the "installed" block)
GMAIL_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_PROJECT_ID=certificate-automation      # your GCP project ID (optional but good to have)

# Token file — saved automatically after first browser auth, do not share
GMAIL_TOKEN_FILE=gmail_token.json

# ── Email content ─────────────────────────────────────────────────────────────
EMAIL_SUBJECT=Congratulations — Your Certificate is Here!
EMAIL_FROM_NAME=Your Organisation
EMAIL_TEMPLATE_DIR=email_sender/templates
DEFAULT_TEMPLATE=default.html

# ── CSV / paths ───────────────────────────────────────────────────────────────
CSV_PATH=data/recipients.csv
OUTPUT_DIR=data/output

# CSV column mapping  (FilmFreeway export defaults shown)
CSV_FIRST_NAME_COL=First Name
CSV_LAST_NAME_COL=Last Name
CSV_EMAIL_COL=Email
CSV_PROJECT_COL=Project Title
CSV_CATEGORY_COL=Submission Categories

# Optional: only process rows where Submission Status == this value
# Leave blank to process all rows
CSV_FILTER_STATUS=

# ── Misc ──────────────────────────────────────────────────────────────────────
DRY_RUN=false
