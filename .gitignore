# Credentials — never commit these
.env
projects/**/.env
# GCP service account keys
*-[0-9a-f]*.json
*service*account*.json
projects/**/gmail_token.json
canva_token.json
gmail_token.json
credentials.json

# Keep example, template and asset files
!.env.example
!projects/project_name.env.example
!projects/**/templates/
!projects/**/templates/**
!projects/**/assets/
!projects/**/assets/**

# Output
data/output/

# Real recipient CSV exports (contain PII — never commit)
data/*.csv
!data/*.example.csv

# Python
__pycache__/
*.pyc
.venv/
venv/
