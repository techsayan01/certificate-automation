# Copy this file to projects/<your_project_name>/.env and fill in the values.
# Each project gets its own Gmail account and settings.
# Canva credentials are shared from the root .env.

# ── Gmail credentials ─────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_PROJECT_ID=your-gcp-project-id
GMAIL_TOKEN_FILE=projects/<project_name>/gmail_token.json   # auto-created on first run

# ── Email content ─────────────────────────────────────────────────────────────
EMAIL_SUBJECT=Congratulations — Your Certificate is Here!
EMAIL_FROM_NAME=Your Festival / Organisation Name

# ── CSV ───────────────────────────────────────────────────────────────────────
CSV_PATH=data/<project_name>_recipients.csv

# Column names in your CSV (change only if different from FilmFreeway defaults)
CSV_FIRST_NAME_COL=First Name
CSV_LAST_NAME_COL=Last Name
CSV_EMAIL_COL=Email
CSV_PROJECT_COL=Project Title
CSV_CATEGORY_COL=Submission Categories

# Optional: only process rows where Submission Status matches this value
# Leave blank to process all rows
CSV_FILTER_STATUS=
