# ─────────────────────────────────────────────────────────────────────────────
# Per-project config template
# Copy to:  projects/<festival_name>/.env  and fill in the values.
#
# Directory structure for a new project:
#
#   projects/
#     <festival_name>/
#       .env                        ← this file (fill in below)
#       templates/
#         category_map.json         ← maps category names → template filenames
#         default.html              ← fallback template for this festival
#         best_student_film.html    ← one file per award category
#         best_documentary.html
#         ...
#       gmail_token.json            ← auto-created on first run (do not commit)
#
# Template resolution order:
#   1. projects/<name>/templates/<category>.html   (project-specific)
#   2. projects/<name>/templates/default.html      (project default)
#   3. email_sender/templates/<category>.html      (global fallback)
#   4. email_sender/templates/default.html         (final fallback)
# ─────────────────────────────────────────────────────────────────────────────

# ── Gmail credentials ─────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GMAIL_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_PROJECT_ID=your-gcp-project-id
GMAIL_TOKEN_FILE=projects/<festival_name>/gmail_token.json
GMAIL_SENDER_EMAIL=sender@gmail.com           # the Gmail account sending the emails

# ── Email content ─────────────────────────────────────────────────────────────
EMAIL_SUBJECT=Congratulations — Your Certificate is Here!
EMAIL_FROM_NAME=Your Festival Name

# ── CSV (from FilmFreeway or any compatible export) ───────────────────────────
CSV_PATH=data/<festival_name>.csv

# Column names — change only if different from FilmFreeway defaults
CSV_FIRST_NAME_COL=First Name
CSV_LAST_NAME_COL=Last Name
CSV_EMAIL_COL=Email
CSV_PROJECT_COL=Project Title
CSV_CATEGORY_COL=Submission Categories

# Filter rows by Submission Status (leave blank to process all rows)
CSV_FILTER_STATUS=
